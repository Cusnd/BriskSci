---
// Projects Section - reads project data from config/site.yaml
import { getConfig } from "../config";
import { getLangFromUrl } from "../i18n/utils";
import { Github, ExternalLink, FolderGit2 } from "lucide-astro";

interface Props {
    lang?: "en" | "zh";
}

const { lang: langFromProps } = Astro.props as Props;
const lang = langFromProps ?? getLangFromUrl(Astro.url);
const config = getConfig(lang);

const projects = config.projects ?? [];

// Accent colour palette cycling for project cards
const cardAccents = [
    { bg: "bg-sakura-light/30", text: "text-sakura-dark", border: "border-sakura-light" },
    { bg: "bg-blue-100/50",     text: "text-blue-600",    border: "border-blue-200"   },
    { bg: "bg-purple-100/50",   text: "text-purple-600",  border: "border-purple-200" },
    { bg: "bg-amber-100/50",    text: "text-amber-600",   border: "border-amber-200"  },
    { bg: "bg-green-100/50",    text: "text-green-600",   border: "border-green-200"  },
];

const sectionLabel = lang === "zh" ? "开源项目" : "Projects";
const sectionSub   = lang === "zh"
    ? "一些我构建并开源的项目。"
    : "A collection of things I've built and shipped.";
const viewAllLabel = lang === "zh" ? "查看全部" : "View all";
---

{projects.length > 0 && (
<section id="projects" class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
        <!-- Section Header -->
        <div class="flex items-center justify-between mb-10">
            <div class="flex items-center gap-3">
                <div class="p-2 rounded-xl bg-sakura-light/30 text-sakura-dark">
                    <FolderGit2 size={24} />
                </div>
                <div>
                    <h2 class="text-2xl md:text-3xl font-serif font-bold text-slate-800">
                        {sectionLabel}
                    </h2>
                    <p class="text-slate-500 text-sm mt-0.5">{sectionSub}</p>
                </div>
            </div>
            <a
                href={`/${lang}/projects`}
                class="hidden sm:flex items-center gap-1 text-sm font-medium text-sakura-dark hover:opacity-75 transition-opacity"
            >
                {viewAllLabel} →
            </a>
        </div>

        <!-- Project Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {projects.map((project, i) => {
                const accent = cardAccents[i % cardAccents.length];
                return (
                    <div class="glass p-6 rounded-2xl flex flex-col h-full group project-card">
                        <!-- Icon badge -->
                        <div class={`w-11 h-11 rounded-xl ${accent.bg} flex items-center justify-center text-xl mb-5 transition-transform duration-300 group-hover:scale-110`}>
                            {project.icon ?? "🗂️"}
                        </div>

                        <!-- Title -->
                        <h3 class={`text-lg font-bold text-slate-800 mb-2 group-hover:${accent.text} transition-colors`}>
                            {project.title}
                        </h3>

                        <!-- Description -->
                        <p class="text-slate-600 text-sm leading-relaxed mb-5 flex-1">
                            {project.description}
                        </p>

                        <!-- Tags -->
                        <div class="flex flex-wrap gap-1.5 mb-5">
                            {project.tags.map((tag) => (
                                <span class={`text-xs font-medium px-2.5 py-1 rounded-full bg-white/60 border ${accent.border} text-slate-600`}>
                                    {tag}
                                </span>
                            ))}
                        </div>

                        <!-- Links -->
                        <div class="flex gap-4 pt-4 border-t border-slate-100/60">
                            {project.github && (
                                <a
                                    href={project.github}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-sakura-dark transition-colors"
                                >
                                    <Github size={14} />
                                    <span class="font-serif">Code</span>
                                </a>
                            )}
                            {project.link && project.link !== "#" && (
                                <a
                                    href={project.link}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-sakura-dark transition-colors"
                                >
                                    <ExternalLink size={14} />
                                    <span class="font-serif">Demo</span>
                                </a>
                            )}
                        </div>
                    </div>
                );
            })}
        </div>

        <!-- Mobile "View all" link -->
        <div class="mt-8 text-center sm:hidden">
            <a
                href={`/${lang}/projects`}
                class="inline-flex items-center gap-1 text-sm font-medium text-sakura-dark hover:opacity-75 transition-opacity"
            >
                {viewAllLabel} →
            </a>
        </div>
    </div>
</section>
)}

<style>
    .project-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    }
</style>
